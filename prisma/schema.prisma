// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Round {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  status           String    // CREATED | STARTED | REVEALED
  nonce            String
  commitHex        String
  serverSeed       String?
  clientSeed       String    @default("")
  combinedSeed     String    @default("")
  pegMapHash       String    @default("")
  rows             Int       @default(12)
  risk             String    @default("MEDIUM")
  dropColumn       Int       @default(6)
  binIndex         Int       @default(0)
  payoutMultiplier Float     @default(1.0)
  betCents         Int       @default(100)
  pathJson         Json      @default("[]")
  revealedAt       DateTime?
}
